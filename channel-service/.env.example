# Copy to .env and adjust.

# Simulation knobs — these drive the "realism" of the stubbed channel.
FAILURE_RATE=0.10          # fraction of messages that fail to deliver
OPEN_RATE=0.55             # fraction of delivered messages that get opened
CLICK_RATE=0.20            # fraction of opened messages that get clicked
MIN_DELAY_MS=500           # min async delay before first callback
MAX_DELAY_MS=8000          # max async delay (events arrive out of order)
CALLBACK_MAX_RETRIES=3     # retries if the CRM receipt API is unreachable
