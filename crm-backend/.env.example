# Copy to .env and fill in.

# Postgres connection (Neon / local docker / Render)
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/brewhaus

# Where the stubbed channel service lives
CHANNEL_SERVICE_URL=http://localhost:8001

# Public URL of THIS crm-backend, so the channel service knows where to
# send async receipts. In local dev this is localhost.
CRM_PUBLIC_URL=http://localhost:8000

# AI provider config (default: Google Gemini, free tier)
AI_PROVIDER=gemini
GEMINI_API_KEY=your_key_from_https://aistudio.google.com
GEMINI_MODEL=gemini-2.5-flash-lite

# Optional fallback provider — used automatically when the primary is rate-limited.
GROQ_API_KEY=optional_key_from_https://console.groq.com
GROQ_MODEL=llama-3.3-70b-versatile

# Image generation (optional) — free token at https://huggingface.co/settings/tokens
HF_TOKEN=optional_hf_token
HF_IMAGE_MODEL=black-forest-labs/FLUX.1-schnell
